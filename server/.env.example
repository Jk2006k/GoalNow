# IMPORTANT: Create this file at server/.env
# This file contains sensitive credentials - DO NOT commit to git
# It's in .gitignore for security

# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/goalnow
# For MongoDB Atlas (cloud): mongodb+srv://username:password@cluster-name.mongodb.net/goalnow
MONGODB_URI=mongodb://localhost:27017/goalnow

# Google OAuth Credentials
# Get these from: https://console.cloud.google.com
# Under Credentials → OAuth 2.0 Client IDs → Web application
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Secret for signing tokens
# Use a long random string (minimum 32 characters)
# Generate one: https://www.uuidgenerator.net/
JWT_SECRET=your_super_secret_jwt_key_here_minimum_32_characters

# Server Port
PORT=5000

# Optional: Node Environment
NODE_ENV=development

# OpenRouter API Key for AI Analysis
# Get API key from: https://openrouter.ai
# For evaluating interview answers using Claude Opus
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# Google Gemini API Key
# Get API key from: https://ai.google.dev
# For evaluating interview answers using Gemini 1.5 Flash
# Free tier: 15 requests per minute, 1M tokens per day
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) Other AI Provider Keys
# Groq Cloud API Key (OpenAI-compatible endpoint)
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Optional model override (default: llama-3.1-8b-instant)
GROQ_MODEL=llama-3.1-8b-instant
# Optional Groq vision model for screenshot analysis fallback
# Try current Groq multimodal-capable models from docs/deprecations page
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# XAI Grok API Key (used as fallback)
XAI_GROK_API_KEY=your_xai_grok_api_key_here
